# Local Claude Code settings (permissions, per-project overrides)
.claude/settings.local.json

# Python build / test artifacts
__pycache__/
*.py[cod]
.venv/
.mypy_cache/
.pytest_cache/
.coverage
*.egg-info/

# C / BPF build artifacts
*.o
*.bpf.o
compile_commands.json
build/

# Generated kernel type introspection (rebuilt via `bpftool btf dump`)
src/vmlinux.h

# Editor scratch
*.swp
.DS_Store

# D015 test-results DAG: regenerated by pytest producer on every run.
# Captured_git_sha shifts each commit, so committing this would
# produce per-push diff noise. Audit's bootstrap mode handles the
# "no DAG yet" case on fresh clones; pre-push hook runs pytest
# (which populates it) before invoking the audit.
tooling/iomoments-test-results.json

# fcntl lock sidecars for both ontology and test-results DAGs.
tooling/iomoments-*.json.lock

# Debian package build artifacts (regenerated by dpkg-buildpackage).
# Source-of-truth files under debian/ are tracked explicitly; everything
# else is staging output.
debian/.debhelper/
debian/iomoments/
debian/files
debian/debhelper-build-stamp
debian/*.debhelper.log
debian/*.substvars

# .deb / .ddeb / .buildinfo / .changes land in the parent of the source
# tree by default; ignore them if they ever appear inside the working
# tree (e.g. under build/) too.
*.deb
*.ddeb
*.buildinfo
*.changes
